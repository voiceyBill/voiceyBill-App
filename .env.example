# ─── API ──────────────────────────────────────────────────────────────────────
# Use your PC's local IP for Expo Go on a physical device (NOT localhost).
# Find your IP: ipconfig (Windows) | ifconfig (Mac/Linux)
EXPO_PUBLIC_API_URL=http://192.168.1.100:8000/api

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_key_here
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_key_here
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_key_here
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=your_key_here
EXPO_PUBLIC_GOOGLE_AUTH_ENDPOINT=/auth/google
